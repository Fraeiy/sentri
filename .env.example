# Telegram API credentials — obtain from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Optional: override default paths
# SENTRI_DATA_DIR=./data
# SENTRI_DB_PATH=./data/sentri.db
# SENTRI_SESSION_PATH=./data/session
# SENTRI_LOG_LEVEL=INFO
# SENTRI_LOG_FILE=./data/sentri.log

# Web dashboard (sentri web)
# SENTRI_WEB_HOST=127.0.0.1
# SENTRI_WEB_PORT=8080
# SENTRI_WEB_TOKEN=your_secret_token_here